# ============================================================
# Cryptora Casino Backend — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
SITE_URL=https://cryptora.live

# ── Security (REQUIRED — generate with: openssl rand -hex 32) ─
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
SUPER_ADMIN_ID=

# ── PostgreSQL (REQUIRED) ────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=casino
PG_PASSWORD=CHANGE_ME
PG_DATABASE=casino_db

# ── ClickHouse (analytics — optional but recommended) ────────
CH_HOST=http://localhost:8123
CH_DATABASE=casino
CH_USER=default
CH_PASSWORD=

# ── Master HD Wallet Mnemonic (REQUIRED for crypto deposits) ─
# Generate once: node -e "const b=require('bip39');console.log(b.generateMnemonic(256))"
# WARNING: losing this = losing all player deposit addresses
MASTER_MNEMONIC=

# ── Hot Wallet Keys (REQUIRED for withdrawals) ───────────────
# EVM chains (ETH, BSC, POLYGON): one key covers all
HOT_WALLET_EVM_ADDRESS=
HOT_WALLET_EVM_KEY=

# Tron
HOT_WALLET_TRX_ADDRESS=
HOT_WALLET_TRX_KEY=
HOT_WALLET_TRX_PRIVATE_KEY=

# Bitcoin / Litecoin (shared key)
HOT_WALLET_BTC_ADDRESS=
HOT_WALLET_BTC_KEY=

# Solana
HOT_WALLET_SOL_KEY=

# XRP
HOT_WALLET_XRP_KEY=

# ── TronGrid API (for TRX/USDT monitoring) ───────────────────
TRONGRID_API_KEY=

# ── Blockchain Node Keys ──────────────────────────────────────
# TON Center API key (for TON monitoring)
TONCENTER_API_KEY=

# ── Game Providers ───────────────────────────────────────────
# GrandX / Pragmatic Play / NetEnt / Play'n GO (same credentials)
PRAGMATIC_OPERATOR_ID=
PRAGMATIC_PRIVATE_KEY=
PRAGMATIC_API_URL=https://gs2.grandx.pro/euro-extern/dispatcher/egame/openGame/v2
CALLBACK_URL=https://cryptora.live/api/functions/walletApi

# game-services.work RGS
RGS_OPERATOR_ID=
RGS_ACCESS_TOKEN=
RGS_AUTH_TOKEN=
RGS_LAUNCH_URL=https://ss.game-services.work/platform/api/game/launch
RGS_GAMES_URL=https://ss.game-services.work/platform/api/games

# ── Telegram Bot (for /land auth) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

# ── Email (optional — verification codes) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cryptora.live

# ── SMS (optional — phone verification via smsc.ru) ──────────
SMSC_LOGIN=
SMSC_PASSWORD=

# ── SQLite (MIGRATION ONLY — not used at runtime) ────────────
# Only needed if migrating from old SQLite database:
# DB_PATH=./casino.db
# ALLOW_MIGRATE=true

# ── Stripe (not implemented — placeholder) ───────────────────
# STRIPE_SECRET_KEY=
